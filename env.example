# Conversa Mobile - Environment Variables
# Copy this file to .env.test, .env.dev, or .env.prod based on your environment

# ============================================
# API Configuration
# ============================================
# Test: http://localhost:4000 (local backend)
# Dev: https://api-dev.conversa.app (test backend)
# Prod: https://api.conversa.app (production backend)
EXPO_PUBLIC_API_URL=http://localhost:4000

# ============================================
# RevenueCat Configuration
# ============================================
# Get these from RevenueCat dashboard
# Test/Dev: Use test API keys
# Prod: Use production API keys
EXPO_PUBLIC_RC_IOS_API_KEY=your_revenuecat_ios_api_key_here
EXPO_PUBLIC_RC_ANDROID_API_KEY=your_revenuecat_android_api_key_here

# ============================================
# AdMob Configuration
# ============================================
# Test: Use test IDs (already in code)
# Dev/Prod: Get from AdMob dashboard
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=ca-app-pub-3940256099942544/5224354917
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=ca-app-pub-3940256099942544/6300978111
EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID=ca-app-pub-3940256099942544/1033173712

# ============================================
# Expo Project ID (for EAS)
# ============================================
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id_here

# ============================================
# Google Authentication
# ============================================
# Get these from Google Cloud Console
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Create OAuth 2.0 credentials
# 5. Add authorized redirect URIs for your app
# For iOS: Use your bundle identifier
# For Android: Use your package name and SHA-1 fingerprint
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id_here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# ============================================
# Environment
# ============================================
# Automatically set by EAS build profiles
# test: Expo Go
# dev: Development build
# prod: Production build
EXPO_PUBLIC_ENV=test
