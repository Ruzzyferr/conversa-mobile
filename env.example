# Swiip Mobile - Environment Variables
# Copy this file to .env.test, .env.dev, or .env.prod based on your environment

# ============================================
# API Configuration
# ============================================
# Test: http://localhost:4000 (local backend)
# Dev: https://api-dev.swiip.app (test backend)
# Prod: https://api.swiip.app (production backend)
EXPO_PUBLIC_API_URL=http://localhost:4000

# ============================================
# RevenueCat Configuration
# ============================================
# Get these from RevenueCat dashboard
# Test/Dev: Use test API keys
# Prod: Use production API keys
EXPO_PUBLIC_RC_IOS_API_KEY=your_revenuecat_ios_api_key_here
EXPO_PUBLIC_RC_ANDROID_API_KEY=your_revenuecat_android_api_key_here

# ============================================
# AdMob Configuration
# ============================================
# Test: Use test IDs (already in code)
# Dev/Prod: Get from AdMob dashboard
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID=ca-app-pub-3940256099942544/5224354917

# ============================================
# Expo Project ID (for EAS)
# ============================================
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id_here

# ============================================
# Environment
# ============================================
# Automatically set by EAS build profiles
# test: Expo Go
# dev: Development build
# prod: Production build
EXPO_PUBLIC_ENV=test
